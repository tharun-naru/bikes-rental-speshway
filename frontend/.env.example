# API Base URL (IMPORTANT: Set this for production)
# Example: VITE_API_URL=https://your-backend-domain.com/api
VITE_API_URL=http://localhost:9000/api

# Proxy target for local development (Vite only)
VITE_API_PROXY_TARGET=http://localhost:9000

# Optional: Disable proxy in development
# VITE_SKIP_PROXY=true

# Sentry DSN (Optional)
# VITE_SENTRY_DSN=your-sentry-dsn

# Google Maps API Key (If used)
# VITE_GOOGLE_MAPS_KEY=your-api-key
